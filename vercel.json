{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/panel", "dest": "/api/panel.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
