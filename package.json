{
  "name": "vortex",
  "version": "1.0.0",
  "description": "VORTEX - License Management System",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server/index.js",
    "license": "electron electron-main.js",
    "panel": "electron electron-panel.js",
    "build:license": "electron-builder --win --x64 --config electron-builder.license.json",
    "build:panel": "electron-builder --win --x64 --config electron-builder.panel.json",
    "build:all": "npm run build:license && npm run build:panel"
  },
  "dependencies": {
    "@edgeone/pages-blob": "^0.0.14",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "localtunnel": "^2.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
