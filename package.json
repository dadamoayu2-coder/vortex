{
  "name": "vortex",
  "version": "1.1.0",
  "description": "VORTEX - License Management System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "panel": "electron electron-panel.js",
    "launcher": "electron electron-launcher.js",
    "build:panel": "electron-builder --win --x64 --config electron-builder.panel.json",
    "build:launcher": "electron-builder --win --x64 --config electron-builder.launcher.json",
    "build:all": "npm run build:panel && npm run build:launcher"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
